#!/usr/bin/env python3
"""
slum-cli
Pulls data from open-slum.org (Uptime Kuma backend)
"""

import sys
import json
import time
import os
import urllib.request

# ─────────────────────────────────────────────
#  USER CONFIG
# ─────────────────────────────────────────────

# avoid hitting api too often
CACHE_TIMEOUT = 5 * 60  # 5 minutes

# empty list shows all
FILTER_KEYWORDS = ["anna"]

# Group names (from the API) to skip entirely
# "Overall Health Summary" is an aggregate group on open-slum.org containing
# parent monitors with no URLs — not useful
EXCLUDE_GROUPS = ["overall health summary"]

# cache location
CACHE_FILE = os.path.join(os.path.expanduser("~"), ".cache", "slum_cache.json")

# ─────────────────────────────────────────────
#  INTERNALS
# ─────────────────────────────────────────────

BASE = "https://open-slum.org/api/status-page"
SLUG = "slum"

GREEN  = "\033[92m"
RED    = "\033[91m"
YELLOW = "\033[93m"
BOLD   = "\033[1m"
DIM    = "\033[2m"
RESET  = "\033[0m"


def fetch(url):
    req = urllib.request.Request(url, headers={"User-Agent": "slum-cli/1.0"})
    with urllib.request.urlopen(req, timeout=10) as r:
        return json.loads(r.read())


def load_cache():
    try:
        with open(CACHE_FILE) as f:
            cache = json.load(f)
        age = time.time() - cache.get("timestamp", 0)
        if age < CACHE_TIMEOUT:
            return cache["page"], cache["heartbeat"], age
    except (FileNotFoundError, json.JSONDecodeError, KeyError):
        pass
    return None, None, None


def save_cache(page, heartbeat):
    os.makedirs(os.path.dirname(CACHE_FILE), exist_ok=True)
    with open(CACHE_FILE, "w") as f:
        json.dump({"timestamp": time.time(), "page": page, "heartbeat": heartbeat}, f)


def matches_filter(name):
    if not FILTER_KEYWORDS:
        return True
    return any(kw.lower() in name.lower() for kw in FILTER_KEYWORDS)


def normalize_group_name(name):
    return (name or "").strip().lower()


def main():
    page_data, heartbeat_data, cache_age = load_cache()

    if page_data is None:
        try:
            page_data      = fetch(f"{BASE}/{SLUG}")
            heartbeat_data = fetch(f"{BASE}/heartbeat/{SLUG}")
            save_cache(page_data, heartbeat_data)
            cache_age = None  # fresh
        except Exception as e:
            print(f"{RED}Error fetching data: {e}{RESET}")
            sys.exit(1)

    # Build id -> {name, url} and id -> group maps
    monitors = {}
    groups   = {}
    for group in page_data.get("publicGroupList", []):
        group_name = (group.get("name", "Unknown") or "Unknown").strip()
        for m in group.get("monitorList", []):
            mid = str(m["id"])
            monitors[mid] = {"name": m["name"], "url": m.get("url") or ""}
            groups[mid]   = group_name

    heartbeats = heartbeat_data.get("heartbeatList", {})

    # Group output by group name, applying keyword + group exclusion filters
    grouped = {}
    excluded_groups = {normalize_group_name(name) for name in EXCLUDE_GROUPS}

    for mid, info in monitors.items():
        if not matches_filter(info["name"]):
            continue
        g = groups.get(mid, "Other")
        normalized_group = normalize_group_name(g)
        if normalized_group in excluded_groups:
            continue
        grouped.setdefault(g, []).append((mid, info))

    # Build display rows and compute totals once
    display_groups = []
    total = up = 0

    for group_name, members in grouped.items():
        real = [(mid, info) for mid, info in members if mid in heartbeats]
        if not real:
            continue

        rows = []
        for mid, info in real:
            hb     = heartbeats[mid]
            last   = hb[-1] if hb else {}
            status = last.get("status", -1)
            ping   = last.get("ping")
            name   = info["name"]
            url    = info["url"]

            total += 1
            if status == 1:
                up     += 1
                icon    = f"{GREEN}● UP  {RESET}"
                ping_s  = f"{ping} ms" if ping else "— ms"
            elif status == 0:
                icon    = f"{RED}● DOWN{RESET}"
                ping_s  = "—"
            else:
                icon    = f"{YELLOW}● ?   {RESET}"
                ping_s  = "—"

            url_display = url if url else f"{DIM}(no url){RESET}"
            rows.append((icon, name, ping_s, url_display))

        display_groups.append((group_name, rows))

    # Header
    print(f"\n{BOLD}{'SLUM — Shadow Library Uptime Monitor':^60}{RESET}")
    print(f"{DIM}{'open-slum.org':^60}{RESET}")
    if cache_age is not None:
        mins = int(cache_age // 60)
        secs = int(cache_age % 60)
        print(f"{DIM}{'(cached ' + f'{mins}m {secs}s ago)':^60}{RESET}")
    else:
        print(f"{DIM}{'(live)':^60}{RESET}")

    print()

    for group_name, rows in display_groups:

        print(f"{BOLD}{YELLOW}{group_name}{RESET}")
        print(f"{DIM}{'─' * 58}{RESET}")

        for icon, name, ping_s, url_display in rows:
            print(f"  {icon}  {name:<28} {DIM}{ping_s:<12}{RESET}  {url_display}")

        print()

    if total == 0:
        print(f"  {YELLOW}No monitors matched your FILTER_KEYWORDS.{RESET}\n")
        return

    down  = total - up
    pct   = int(up / total * 100) if total else 0
    color = GREEN if pct >= 70 else (YELLOW if pct >= 40 else RED)
    print(f"{DIM}{'─' * 58}{RESET}")
    print(f"  {BOLD}Up: {color}{up}/{total}{RESET}{BOLD}  ({pct}%)  |  Down: {RED}{down}{RESET}")
    print()


if __name__ == "__main__":
    main()
